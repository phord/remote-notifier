{
  "private": true,
  "workspaces": [
    "packages/main",
    "packages/router",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint packages/*/src/**/*.ts shared/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts shared/**/*.ts --fix",
    "test": "vitest run",
    "test:unit": "vitest run --include 'packages/*/test/unit/**/*.test.ts'",
    "test:integration": "vitest run --include 'packages/*/test/integration/**/*.test.ts'",
    "test:e2e": "vitest run --include 'test/e2e/**/*.test.ts'",
    "test:coverage": "vitest run --coverage",
    "package": "npm run build && npm run package -w remote-notifier && npm run package -w remote-notifier-router"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "esbuild": "0.28.0",
    "node-notifier": "^10.0.1"
  }
}
